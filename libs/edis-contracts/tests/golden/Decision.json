{
  "$defs": {
    "Evidence": {
      "description": "An immutable value snapshot plus a live pointer back to the source.",
      "properties": {
        "evidence_id": {
          "format": "uuid",
          "title": "Evidence Id",
          "type": "string"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "ref": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ref"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "snapshot": {
          "additionalProperties": true,
          "title": "Snapshot",
          "type": "object"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "kind",
        "summary"
      ],
      "title": "Evidence",
      "type": "object"
    }
  },
  "description": "An explainability record linking an AI decision to its evidence trail.",
  "properties": {
    "actor": {
      "additionalProperties": true,
      "title": "Actor",
      "type": "object"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "decision_id": {
      "format": "uuid",
      "title": "Decision Id",
      "type": "string"
    },
    "decision_type": {
      "enum": [
        "finding_narrative",
        "recommendation",
        "copilot_answer"
      ],
      "title": "Decision Type",
      "type": "string"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/Evidence"
      },
      "title": "Evidence",
      "type": "array"
    },
    "rationale": {
      "title": "Rationale",
      "type": "string"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "subject_id": {
      "format": "uuid",
      "title": "Subject Id",
      "type": "string"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    }
  },
  "required": [
    "decision_id",
    "tenant_id",
    "decision_type",
    "subject_id",
    "rationale",
    "created_at"
  ],
  "title": "Decision",
  "type": "object"
}
