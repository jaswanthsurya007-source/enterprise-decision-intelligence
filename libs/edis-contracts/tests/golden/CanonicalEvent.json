{
  "description": "Payload of ``edis.canonical.<entity>.v1`` -- one event type, ``op`` field.\n\n``is_late`` is always ``False`` in the MVP (no watermark reordering);\n``correction_of`` links a ``corrected`` event to the row it supersedes.",
  "properties": {
    "after": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "After"
    },
    "before": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Before"
    },
    "canonical_id": {
      "format": "uuid",
      "title": "Canonical Id",
      "type": "string"
    },
    "correction_of": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Correction Of"
    },
    "emitted_at": {
      "format": "date-time",
      "title": "Emitted At",
      "type": "string"
    },
    "entity": {
      "enum": [
        "customer",
        "product",
        "order"
      ],
      "title": "Entity",
      "type": "string"
    },
    "event_id": {
      "format": "uuid",
      "title": "Event Id",
      "type": "string"
    },
    "is_late": {
      "default": false,
      "title": "Is Late",
      "type": "boolean"
    },
    "lineage_run_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lineage Run Id"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "op": {
      "enum": [
        "created",
        "updated",
        "corrected"
      ],
      "title": "Op",
      "type": "string"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    }
  },
  "required": [
    "event_id",
    "tenant_id",
    "entity",
    "op",
    "occurred_at",
    "emitted_at",
    "canonical_id"
  ],
  "title": "CanonicalEvent",
  "type": "object"
}
