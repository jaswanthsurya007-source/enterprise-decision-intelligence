{
  "$defs": {
    "SourceRef": {
      "description": "Provenance back-link from a canonical row to a source record.",
      "properties": {
        "match_confidence": {
          "default": 1.0,
          "title": "Match Confidence",
          "type": "number"
        },
        "schema_version": {
          "title": "Schema Version",
          "type": "integer"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "source_system": {
          "title": "Source System",
          "type": "string"
        }
      },
      "required": [
        "source_system",
        "source_id",
        "schema_version"
      ],
      "title": "SourceRef",
      "type": "object"
    }
  },
  "description": "SCD-2-shaped customer dimension (history is designed-future).",
  "properties": {
    "canonical_customer_id": {
      "format": "uuid",
      "title": "Canonical Customer Id",
      "type": "string"
    },
    "country_iso2": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Country Iso2"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "display_name": {
      "title": "Display Name",
      "type": "string"
    },
    "dq_score": {
      "title": "Dq Score",
      "type": "number"
    },
    "industry": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Industry"
    },
    "is_current": {
      "default": true,
      "title": "Is Current",
      "type": "boolean"
    },
    "legal_name": {
      "title": "Legal Name",
      "type": "string"
    },
    "primary_email": {
      "anyOf": [
        {
          "format": "email",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Primary Email"
    },
    "record_hash": {
      "title": "Record Hash",
      "type": "string"
    },
    "region": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Region"
    },
    "source_refs": {
      "items": {
        "$ref": "#/$defs/SourceRef"
      },
      "title": "Source Refs",
      "type": "array"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "valid_from": {
      "format": "date-time",
      "title": "Valid From",
      "type": "string"
    },
    "valid_to": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Valid To"
    },
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "canonical_customer_id",
    "tenant_id",
    "legal_name",
    "display_name",
    "valid_from",
    "source_refs",
    "dq_score",
    "record_hash",
    "created_at",
    "updated_at"
  ],
  "title": "CanonicalCustomer",
  "type": "object"
}
