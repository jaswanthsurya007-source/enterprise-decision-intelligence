{
  "$defs": {
    "EvidenceItem": {
      "description": "One computed fact the narrator is permitted to cite.",
      "properties": {
        "dimensions": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Dimensions",
          "type": "object"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "metric_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric Key"
        },
        "ref": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ref"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "values": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Values",
          "type": "object"
        }
      },
      "required": [
        "kind",
        "summary"
      ],
      "title": "EvidenceItem",
      "type": "object"
    }
  },
  "description": "The *only* thing the LLM may reason over when narrating a finding.",
  "properties": {
    "allowed_numbers": {
      "items": {
        "type": "number"
      },
      "title": "Allowed Numbers",
      "type": "array"
    },
    "bundle_id": {
      "format": "uuid",
      "title": "Bundle Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "finding_id": {
      "format": "uuid",
      "title": "Finding Id",
      "type": "string"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/EvidenceItem"
      },
      "title": "Items",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    }
  },
  "required": [
    "bundle_id",
    "tenant_id",
    "finding_id",
    "created_at"
  ],
  "title": "EvidenceBundle",
  "type": "object"
}
