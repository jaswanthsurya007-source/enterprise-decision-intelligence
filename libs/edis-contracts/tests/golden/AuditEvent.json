{
  "description": "Payload of ``edis.governance.audit.v1`` -- emitted by every layer.\n\n``audit_id`` is the idempotency key (the audit consumer dedupes on it).",
  "properties": {
    "action": {
      "enum": [
        "DATA_READ",
        "DATA_WRITE",
        "AI_DECISION",
        "AI_QUERY",
        "AUTH_DENY",
        "RBAC_CHANGE",
        "EXPORT"
      ],
      "title": "Action",
      "type": "string"
    },
    "actor": {
      "additionalProperties": true,
      "title": "Actor",
      "type": "object"
    },
    "audit_id": {
      "format": "uuid",
      "title": "Audit Id",
      "type": "string"
    },
    "decision_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Decision Id"
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "outcome": {
      "enum": [
        "ALLOW",
        "DENY",
        "ERROR"
      ],
      "title": "Outcome",
      "type": "string"
    },
    "reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reason"
    },
    "resource": {
      "additionalProperties": true,
      "title": "Resource",
      "type": "object"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    },
    "trace_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trace Id"
    }
  },
  "required": [
    "audit_id",
    "occurred_at",
    "tenant_id",
    "action",
    "outcome"
  ],
  "title": "AuditEvent",
  "type": "object"
}
