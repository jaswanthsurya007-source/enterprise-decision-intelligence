{
  "$defs": {
    "ConfidenceScore": {
      "description": "Blended confidence. ``components`` keys: insight, evidence, historical_calibration.",
      "properties": {
        "calibration_n": {
          "default": 0,
          "title": "Calibration N",
          "type": "integer"
        },
        "components": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Components",
          "type": "object"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "value"
      ],
      "title": "ConfidenceScore",
      "type": "object"
    },
    "ImpactEstimate": {
      "description": "Estimated business impact of an action, with the auditable inputs used.",
      "properties": {
        "direction": {
          "enum": [
            "increase",
            "decrease",
            "mitigate"
          ],
          "title": "Direction",
          "type": "string"
        },
        "horizon_days": {
          "title": "Horizon Days",
          "type": "integer"
        },
        "inputs": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Inputs",
          "type": "object"
        },
        "method": {
          "title": "Method",
          "type": "string"
        },
        "unit": {
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        },
        "value_high": {
          "title": "Value High",
          "type": "number"
        },
        "value_low": {
          "title": "Value Low",
          "type": "number"
        }
      },
      "required": [
        "value",
        "value_low",
        "value_high",
        "unit",
        "direction",
        "horizon_days",
        "method"
      ],
      "title": "ImpactEstimate",
      "type": "object"
    }
  },
  "description": "Payload of ``edis.decisions.recommendations.v1`` -- a prioritized action.",
  "properties": {
    "action_params": {
      "additionalProperties": true,
      "title": "Action Params",
      "type": "object"
    },
    "action_type": {
      "enum": [
        "operational_fix",
        "pricing_change",
        "inventory_reallocation",
        "customer_outreach",
        "investigate",
        "scale_resource",
        "notify"
      ],
      "title": "Action Type",
      "type": "string"
    },
    "confidence": {
      "$ref": "#/$defs/ConfidenceScore"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "effort_tier": {
      "enum": [
        "xs",
        "s",
        "m",
        "l",
        "xl"
      ],
      "title": "Effort Tier",
      "type": "string"
    },
    "evidence_trail": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Evidence Trail",
      "type": "array"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "explanation_summary": {
      "title": "Explanation Summary",
      "type": "string"
    },
    "impact": {
      "$ref": "#/$defs/ImpactEstimate"
    },
    "narrative": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Narrative"
    },
    "playbook_id": {
      "title": "Playbook Id",
      "type": "string"
    },
    "playbook_version": {
      "title": "Playbook Version",
      "type": "string"
    },
    "priority_rank": {
      "title": "Priority Rank",
      "type": "integer"
    },
    "priority_score": {
      "title": "Priority Score",
      "type": "number"
    },
    "recommendation_id": {
      "format": "uuid",
      "title": "Recommendation Id",
      "type": "string"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "source_finding_id": {
      "format": "uuid",
      "title": "Source Finding Id",
      "type": "string"
    },
    "status": {
      "default": "proposed",
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "expired",
        "in_progress",
        "outcome_recorded"
      ],
      "title": "Status",
      "type": "string"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    }
  },
  "required": [
    "recommendation_id",
    "tenant_id",
    "source_finding_id",
    "playbook_id",
    "playbook_version",
    "title",
    "action_type",
    "impact",
    "effort_tier",
    "confidence",
    "priority_score",
    "priority_rank",
    "explanation_summary",
    "expires_at",
    "created_at"
  ],
  "title": "Recommendation",
  "type": "object"
}
