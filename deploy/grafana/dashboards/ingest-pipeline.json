{
  "__comment": "EDIS Z2 dashboard. Metric names follow the OTel->Prometheus naming the platform emits via libs/edis-platform/otel.py: dots become underscores, counters get a _total suffix, and resource attributes (service.name) become labels (service_name) because the collector has resource_to_telemetry_conversion enabled. Names referenced in deploy/prometheus/prometheus.yml's comment block (ingest_rate, dlq_rate, ...) are the source of truth. ASPIRATIONAL: edis_integration_throughput_total and edis_ingest_quarantine_total are named sensibly here; the integration service does not yet register these instruments (the OTel meter call sites are stubs in the MVP) -- they resolve to no data until wired.",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "records/s",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
          "editorMode": "code",
          "expr": "sum by (domain) (rate(edis_ingest_records_total[$__rate_interval]))",
          "legendFormat": "{{domain}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Ingest rate (records/s by domain)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "records/s",
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
          "editorMode": "code",
          "expr": "sum by (stage) (rate(edis_dlq_records_total[$__rate_interval]))",
          "legendFormat": "{{stage}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "DLQ rate (dead-lettered records/s by stage)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "records/s",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
          "editorMode": "code",
          "expr": "sum by (entity) (rate(edis_integration_upserts_total[$__rate_interval]))",
          "legendFormat": "{{entity}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Integration throughput (canonical upserts/s by entity)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
      "description": "Share of records routed to quarantine (edis.dlq.integration.v1) out of all records the integration pipeline processed. ASPIRATIONAL metric (see __comment).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(edis_integration_quarantine_total[$__rate_interval])) / clamp_min(sum(rate(edis_integration_records_total[$__rate_interval])), 1)",
          "legendFormat": "quarantine ratio",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Quarantine rate (fraction of records quarantined)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["edis", "ingestion", "integration"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "EDIS · Ingest & Integration Pipeline",
  "uid": "edis-ingest-pipeline",
  "version": 1,
  "weekStart": ""
}
