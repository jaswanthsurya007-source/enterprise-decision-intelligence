          "expr": "sum(up)",
          "legendFormat": "targets up",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
          "editorMode": "code",
          "expr": "count(up)",
          "legendFormat": "targets total",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Scrape targets up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
      "description": "Distinct EDIS services currently emitting telemetry through the collector (by service_name resource label).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
