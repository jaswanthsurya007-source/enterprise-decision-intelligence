        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "edis-prometheus" },
          "editorMode": "code",
          "expr": "count(max by (service_name) (edis_service_up == 1)) or count(count by (service_name) ({service_name=~\".+\"}))",
