# EDIS web (L6) — local dev configuration. Copy to `.env.local` (gitignored).

# Base URL of the API Gateway / BFF (services/gateway). No trailing slash.
VITE_GATEWAY_URL=http://localhost:8080

# Dev-mode static JWT (HS256, signed with the shared dev secret the gateway
# validates). Carries {tenant_id, user_id, roles, scopes}. The MVP attaches this
# as `Authorization: Bearer <token>` on every gateway call. OIDC/PKCE is the
# designed-future replacement. NEVER commit a real secret here.
VITE_DEV_JWT=
