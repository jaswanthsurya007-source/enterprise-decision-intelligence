{
  "name": "@edis/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EDIS L6 — Real-Time Operations Dashboard (React + Vite + Tailwind + TanStack Query + Recharts + SSE).",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
