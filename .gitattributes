# Normalize line endings to LF on checkin for all text; let git detect text vs binary.
* text=auto eol=lf

# Explicit text types (force LF even on Windows checkouts) — keeps shell scripts,
# Makefiles, and config byte-identical across platforms and CI.
*.py     text eol=lf
*.pyi    text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.txt    text eol=lf
*.md     text eol=lf
*.rst    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.sql    text eol=lf
*.sh     text eol=lf
*.env    text eol=lf
.env.example text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
.gitattributes text eol=lf
.gitignore     text eol=lf

# Binary assets — never normalize.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.parquet binary
*.gz     binary
*.zip    binary
*.woff   binary
*.woff2  binary
