# EDIS environment — copy to `.env` and adjust. Loaded by docker-compose (env_file)
# and by edis_platform.settings (pydantic-settings, env_prefix="EDIS_").
#
#   cp .env.example .env
#
# Every variable maps 1:1 to a field on edis_platform.settings.Settings.
# Defaults below are laptop-friendly: the in-process bus and localhost services,
# so nothing external is required for `make test`.

# --- identity ---
EDIS_APP_NAME=edis
EDIS_SERVICE_NAME=edis
EDIS_ENVIRONMENT=dev
EDIS_LOG_LEVEL=INFO

# --- datastores ---
# Async DSN (asyncpg). For docker compose, the host is the compose service name
# `postgres`; for running a service on the host against compose infra use localhost.
EDIS_DATABASE_URL=postgresql+asyncpg://edis:edis@localhost:5432/edis
EDIS_REDIS_URL=redis://localhost:6379/0

# --- event bus ---
# Kafka/Redpanda external listener (see docker-compose redpanda advertise addr).
EDIS_KAFKA_BOOTSTRAP_SERVERS=localhost:19092
# sink_backend selects the EventSink/MessageSource impl: kafka | redis | inproc.
# `inproc` needs no broker and is the default for tests and the laptop slice.
EDIS_SINK_BACKEND=inproc

# --- observability ---
EDIS_OTEL_ENABLED=false
EDIS_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- auth (dev static JWT) ---
EDIS_JWT_SECRET=dev-secret-change-me
EDIS_JWT_ALGORITHM=HS256

# --- model providers (optional; copilot/intelligence degrade gracefully without) ---
# EDIS_ANTHROPIC_API_KEY=sk-ant-...
# EDIS_VOYAGE_API_KEY=pa-...
